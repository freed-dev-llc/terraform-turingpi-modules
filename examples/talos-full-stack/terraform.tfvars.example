# Turing Pi BMC credentials
turingpi_endpoint = "https://turingpi.local"
turingpi_username = "root"
turingpi_password = "turing"

# Firmware image: leave unset to use the image generated by the talos-image
# module (recommended — flashed via the BMC URL method). Only override with a
# pre-built image, and match talos_version (default v1.9.2).
# talos_firmware = "/path/to/talos-rk1-v1.9.2.raw.xz"

# Cluster configuration
cluster_name     = "homelab"
control_plane_ip = "10.10.88.73"
worker_ips       = ["10.10.88.74", "10.10.88.75", "10.10.88.76"]

# MetalLB IP range (must be in same subnet as nodes)
metallb_ip_range = "10.10.88.80-10.10.88.89"

# Ingress controller IP (should be within MetalLB range)
ingress_ip = "10.10.88.80"

# Portainer agent IP
portainer_ip = "10.10.88.81"

# Grafana admin password (change this!)
grafana_password = "your-secure-password"
