# K3s Full Stack Example - Variable Values
# Copy this to terraform.tfvars and customize

# SSH key for node access
ssh_key_path = "~/.ssh/id_rsa"

# Node IP addresses
control_plane_ip = "10.10.88.73"
worker_ips = [
  "10.10.88.74",
  "10.10.88.75",
  "10.10.88.76"
]

# MetalLB IP range (must be on same subnet, outside DHCP range)
metallb_ip_range = "10.10.88.80-10.10.88.89"

# Static IPs for services
ingress_ip   = "10.10.88.80"
portainer_ip = "10.10.88.81"

# Grafana password (change this!)
grafana_password = "your-secure-password"
